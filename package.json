{
  "name": "yes-sessions",
  "version": "6.1.0",
  "description": "AI Session Manager - Browse and resume your AI conversations",
  "main": "dist-electron/main.js",
  "author": "Yes, Sessions Team",
  "license": "MIT",
  "private": true,
  "type": "module",
  "build": {
    "productName": "Yes-Sessions",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*.node",
      "node_modules/keytar/**/*.node"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!**/*.map",
      "!dist/mac-arm64",
      "!dist/mac-arm64/**/*",
      "!node_modules",
      "!node_modules/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/keytar/**/*",
      "node_modules/bindings/**/*",
      "node_modules/prebuild-install/**/*",
      "node_modules/node-addon-api/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/electron-log/**/*",
      "node_modules/electron-store/**/*",
      "node_modules/electron-updater/**/*",
      "node_modules/electron/**/*",
      "node_modules/conf/**/*",
      "node_modules/ajv/**/*",
      "node_modules/ajv-formats/**/*",
      "node_modules/dot-prop/**/*",
      "node_modules/atomically/**/*",
      "node_modules/debounce-fn/**/*",
      "node_modules/mimic-fn/**/*",
      "node_modules/type-fest/**/*",
      "node_modules/semver/**/*",
      "node_modules/lazy-val/**/*",
      "node_modules/builder-util-runtime/**/*",
      "node_modules/fs-extra/**/*",
      "node_modules/jsonfile/**/*",
      "node_modules/universalify/**/*",
      "node_modules/js-yaml/**/*",
      "node_modules/argparse/**/*",
      "node_modules/sprintf-js/**/*",
      "node_modules/lodash.isequal/**/*",
      "node_modules/pump/**/*",
      "node_modules/end-of-stream/**/*",
      "node_modules/once/**/*",
      "node_modules/wrappy/**/*",
      "node_modules/simple-get/**/*",
      "node_modules/mkdirp-classic/**/*",
      "node_modules/napi-build-utils/**/*",
      "node_modules/detect-libc/**/*",
      "node_modules/github-from-package/**/*",
      "node_modules/which-pm-runs/**/*",
      "node_modules/tar-fs/**/*",
      "node_modules/tar-stream/**/*",
      "node_modules/bl/**/*",
      "node_modules/readable-stream/**/*",
      "node_modules/inherits/**/*",
      "node_modules/string_decoder/**/*",
      "node_modules/util-deprecate/**/*",
      "node_modules/safe-buffer/**/*",
      "node_modules/buffer/**/*",
      "node_modules/base64-js/**/*",
      "node_modules/ieee754/**/*",
      "node_modules/xtend/**/*",
      "node_modules/fs-constants/**/*",
      "node_modules/chownr/**/*"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run cleanup:build && electron-builder",
    "build:mac": "tsc && vite build && npm run cleanup:build && electron-builder --mac",
    "build:win": "tsc && vite build && npm run cleanup:build && electron-builder --win",
    "build:linux": "tsc && vite build && npm run cleanup:build && electron-builder --linux",
    "cleanup:build": "bash scripts/cleanup-build.sh",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"electron/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\" \"electron/**/*.{ts,json}\"",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-lezer": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@hookform/resolvers": "^3.3.4",
    "@lezer/highlight": "^1.2.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.35.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/diff-match-patch": "^1.0.36",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@uiw/react-md-editor": "^4.1.0",
    "better-sqlite3": "^9.6.0",
    "bytenode": "^1.5.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "diff": "^9.0.0",
    "diff-match-patch": "^1.0.5",
    "electron-log": "^5.1.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.8",
    "express": "^4.22.1",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-http-backend": "^3.0.4",
    "keytar": "^7.9.0",
    "lucide-react": "^0.400.0",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "node-fetch": "^3.3.0",
    "react": "^18.3.0",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.0",
    "react-i18next": "^14.1.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.23.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^2.2.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.10",
    "@types/diff": "^7.0.2",
    "@types/express": "^4.17.25",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.5.0",
    "autoprefixer": "^10.4.19",
    "bytenode-webpack-plugin": "^1.0.5",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "javascript-obfuscator": "^5.4.1",
    "jsdom": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.46.1",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
