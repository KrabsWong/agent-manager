{
  "name": "yes-sessions",
  "version": "9.2.0",
  "description": "AI Session Manager - Browse and resume your AI conversations",
  "main": "dist-electron/main.js",
  "author": "Yes, Sessions Team",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run cleanup:build && electron-builder --publish never",
    "build:mac": "tsc && vite build && npm run cleanup:build && electron-builder --mac --publish never",
    "build:win": "tsc && vite build && npm run cleanup:build && electron-builder --win --publish never",
    "build:linux": "tsc && vite build && npm run cleanup:build && electron-builder --linux --publish never",
    "cleanup:build": "bash scripts/cleanup-build.sh",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "build:e2e": "tsc && vite build",
    "test:e2e": "npm run build:e2e && playwright test",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"electron/**/*.{ts,json}\" \"tests/**/*.{ts,tsx}\" \"e2e/**/*.ts\" \"*.config.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\" \"electron/**/*.{ts,json}\" \"tests/**/*.{ts,tsx}\" \"e2e/**/*.ts\" \"*.config.ts\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.35.0",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "^9.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "diff": "^9.0.0",
    "electron-log": "^5.1.0",
    "electron-store": "^8.2.0",
    "i18next": "^23.16.8",
    "lucide-react": "^0.400.0",
    "mermaid": "^11.14.0",
    "react": "^18.3.0",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^18.3.0",
    "react-i18next": "^14.1.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.23.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^2.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.10",
    "@types/diff": "^7.0.2",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.5.0",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.46.1",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
